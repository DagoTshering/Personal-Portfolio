generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Hero {
  id              String   @id @default(cuid())
  name            String
  title           String
  tagline         String
  ctaText         String   @default("Get in Touch")
  ctaLink         String   @default("#contact")
  resumeUrl       String?
  avatarUrl       String?
  backgroundType  String   @default("gradient") // video, image, gradient
  isVisible       Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model About {
  id              String   @id @default(cuid())
  bio             String   @db.Text
  yearsExperience Int      @default(0)
  location        String
  availability    String   @default("Available for freelance")
  funFacts        Json     @default("[]")
  profileImageUrl String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Skill {
  id                String   @id @default(cuid())
  name              String
  category          SkillCategory
  icon              String
  proficiencyLevel  Int      @default(3) // 1-5
  order             Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([category])
  @@index([order])
}

enum SkillCategory {
  FRONTEND
  BACKEND
  DATABASE
  DEVOPS
  TOOLS
}

model Project {
  id                String   @id @default(cuid())
  title             String
  slug              String   @unique
  description       String
  longDescription   String   @db.Text
  thumbnailUrl      String
  images            Json     @default("[]")
  liveDemoUrl       String?
  githubUrl         String?
  techStack         Json     @default("[]")
  category          ProjectCategory
  featured          Boolean  @default(false)
  order             Int      @default(0)
  published         Boolean  @default(true)
  publishedAt       DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([slug])
  @@index([category])
  @@index([featured])
  @@index([order])
}

enum ProjectCategory {
  WEB_APP
  API
  MOBILE
  OSS
  OTHER
}

model Experience {
  id              String        @id @default(cuid())
  company         String
  role            String
  startDate       DateTime
  endDate         DateTime?
  current         Boolean       @default(false)
  description     Json          @default("[]")
  companyLogoUrl  String?
  location        String
  type            EmploymentType @default(FULLTIME)
  order           Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([current])
  @@index([order])
}

enum EmploymentType {
  FULLTIME
  CONTRACT
  FREELANCE
}

model Testimonial {
  id          String   @id @default(cuid())
  name        String
  role        String
  company     String
  avatarUrl   String?
  quote       String   @db.Text
  rating      Int      @default(5)
  featured    Boolean  @default(false)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([featured])
  @@index([order])
}

model BlogPost {
  id            String   @id @default(cuid())
  title         String
  slug          String   @unique
  content       String   @db.Text
  excerpt       String
  coverImage    String?
  tags          Json     @default("[]")
  published     Boolean  @default(false)
  publishedAt   DateTime @default(now())
  readTime      Int      @default(5) // minutes
  views         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([slug])
  @@index([published])
  @@index([publishedAt])
}

model Service {
  id            String   @id @default(cuid())
  title         String
  description   String
  icon          String
  features      Json     @default("[]")
  highlighted   Boolean  @default(false)
  order         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([highlighted])
  @@index([order])
}

model SocialLink {
  id        String   @id @default(cuid())
  platform  String
  url       String
  icon      String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([order])
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String   @db.Text
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([read])
  @@index([createdAt])
}

model SiteSettings {
  id                  String   @id @default(cuid())
  siteName            String   @default("Developer Portfolio")
  seoTitle            String   @default("Fullstack Developer Portfolio")
  seoDescription      String   @default("Fullstack developer specializing in modern web technologies")
  ogImage             String?
  googleAnalyticsId   String?
  maintenanceMode     Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  isAdmin       Boolean   @default(false)
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
